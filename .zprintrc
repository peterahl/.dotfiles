{:cwd-zprintrc? true
 :map           {:comma?    false
                 :force-nl? true  ; Forces map entries onto new lines
                 :indent    0     ; Aligns values with keys
                 :sort?     true} ; Sorts keys consistently
 :binding       {:indent    0     ; Aligns `let` values with their bindings
                 :force-nl? true} ; Forces each binding pair onto its own
                                  ; line
 :vector        {:wrap? false}
 :pair          {:justify  {:max-variance 1000}
                 :justify? true}
 :style         :justified}
